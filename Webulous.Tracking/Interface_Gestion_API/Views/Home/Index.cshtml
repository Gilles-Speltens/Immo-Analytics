@model WhiteListViewModel
@{
    ViewData["Title"] = "Gestion des adresses IP et des Domaines";
}

<div class="container">

    <!-- Formulaire d'ajout -->
    <div class="mb-4">
        <h2>Ajouter une adresse IP</h2>
        <form asp-action="AddIp" method="post" style="max-width:400px;">
            <div class="form-group">
                <label for="NewIp">Nouvelle adresse IP :</label>
                <input type="text" class="form-control" id="ip" name="Ip" placeholder="ex : 192.168.1.12 ou ::1" required />
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            <button type="submit" class="btn btn-primary mt-2">Ajouter</button>
        </form>
    </div>

    <hr />

    <!-- Listes côte à côte -->
    <div class="row">
        <!-- IPv4 -->
        <div class="col-md-6">
            <h2>Liste IPv4</h2>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Adresse IP</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ip in Model.IPv4)
                    {
                        <tr>
                            <td>@ip.GetIp()</td>
                            <td>
                                <form asp-action="DeleteIp" method="post" style="display:inline;">
                                    <input type="hidden" name="Ip" value="@ip.GetIp()" />
                                    <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- IPv6 -->
        <div class="col-md-6">
            <h2>Liste IPv6</h2>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Adresse IP</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ip in Model.IPv6)
                    {
                        <tr>
                            <td>@ip.GetIp()</td>
                            <td>
                                <form asp-action="DeleteIp" method="post" style="display:inline;">
                                    <input type="hidden" name="Ip" value="@ip.GetIp()" />
                                    <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <!-- Gestion des noms de domaine -->
    <div class="mt-4">

        <!-- Formulaire d'ajout de domaine -->
        <div class="mb-4">
            <h2>Ajouter un nom de domaine</h2>
            <form asp-action="AddDomain" method="post" style="max-width:400px;">
                <div class="form-group">
                    <label for="NewDomain">Nouveau domaine :</label>
                    <input type="text" class="form-control" id="domain" name="Domain" placeholder="ex : example.com" required />
                </div>

                @if (TempData["DomainError"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["DomainError"]
                    </div>
                }

                <button type="submit" class="btn btn-primary mt-2">Ajouter</button>
            </form>
        </div>

        <!-- Tableau des domaines -->
        <h2>Liste des noms de domaine</h2>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Nom de domaine</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var domain in Model.Domains)
                {
                    <tr>
                        <td>@domain</td>
                        <td>
                            <form asp-action="DeleteDomain" method="post" style="display:inline;">
                                <input type="hidden" name="Domain" value="@domain" />
                                <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>
